@@ -8,12 +8,38 @@ export interface SubscriptionData {
   valor: number | null;
   ciclo: "YEARLY" | null;
   proximo_vencimento: string | null;
-  status: "ACTIVE" | "INACTIVE" | "SUSPENDED" | null;
